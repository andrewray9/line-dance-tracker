<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Line Dance Tracker</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #ffffff;
      --bg2: #f5f4f0;
      --bg3: #eeede9;
      --t1: #1a1a18;
      --t2: #6b6a66;
      --t3: #a8a7a3;
      --b1: rgba(0,0,0,0.4);
      --b2: rgba(0,0,0,0.3);
      --b3: rgba(0,0,0,0.15);
      --radius-md: 8px;
      --radius-lg: 12px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #1c1c1a;
        --bg2: #252523;
        --bg3: #2e2e2b;
        --t1: #f0efe9;
        --t2: #9e9d98;
        --t3: #5a5955;
        --b1: rgba(255,255,255,0.4);
        --b2: rgba(255,255,255,0.3);
        --b3: rgba(255,255,255,0.12);
      }
    }

    html, body {
      min-height: 100vh;
      background: var(--bg3);
      color: var(--t1);
      font-family: 'DM Sans', sans-serif;
    }

    .app {
      max-width: 780px;
      margin: 0 auto;
      padding: 2.5rem 1.25rem 4rem;
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -0.5px;
      margin-bottom: 4px;
      color: var(--t1);
    }

    .subtitle {
      font-size: 14px;
      color: var(--t2);
      margin-bottom: 2rem;
    }

    /* Tabs */
    .tab-row {
      display: flex;
      gap: 4px;
      border-bottom: 0.5px solid var(--b3);
      margin-bottom: 1.5rem;
      overflow-x: auto;
    }

    .tab {
      font-size: 13px;
      font-weight: 500;
      padding: 8px 16px;
      cursor: pointer;
      border: none;
      background: none;
      color: var(--t2);
      border-bottom: 2px solid transparent;
      margin-bottom: -0.5px;
      white-space: nowrap;
      font-family: 'DM Sans', sans-serif;
      transition: color 0.15s;
    }

    .tab.active { color: var(--t1); border-bottom-color: var(--t1); }
    .tab:hover:not(.active) { color: var(--t1); }

    /* Sections */
    .section { display: none; }
    .section.visible { display: block; }

    /* Add row */
    .add-row {
      display: flex;
      gap: 8px;
      margin-bottom: 1.25rem;
    }

    .add-row input {
      flex: 1;
      padding: 9px 13px;
      border: 0.5px solid var(--b2);
      border-radius: var(--radius-md);
      background: var(--bg);
      color: var(--t1);
      font-size: 14px;
      font-family: 'DM Sans', sans-serif;
    }

    .add-row input:focus { outline: none; border-color: var(--b1); }
    .add-row input::placeholder { color: var(--t3); }

    /* Buttons */
    button.btn {
      padding: 9px 18px;
      border: 0.5px solid var(--b2);
      border-radius: var(--radius-md);
      background: var(--bg);
      color: var(--t1);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
      transition: background 0.12s, opacity 0.12s;
    }

    button.btn:hover { background: var(--bg2); }

    button.btn.primary {
      background: var(--t1);
      color: var(--bg);
      border-color: var(--t1);
    }

    button.btn.primary:hover { opacity: 0.82; }
    button.btn.sm { padding: 5px 11px; font-size: 12px; }

    button.btn.danger {
      color: #A32D2D;
      border-color: #F7C1C1;
    }

    button.btn.danger:hover { background: #FCEBEB; }

    button.btn.success {
      color: #27500A;
      border-color: #C0DD97;
    }

    button.btn.success:hover { background: #EAF3DE; }

    /* Dance list */
    .dance-list { display: flex; flex-direction: column; gap: 6px; }

    .dance-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 11px 15px;
      border: 0.5px solid var(--b3);
      border-radius: var(--radius-lg);
      background: var(--bg);
    }

    .dance-item .name { flex: 1; font-size: 14px; font-weight: 500; }

    .empty {
      text-align: center;
      padding: 3rem 1rem;
      color: var(--t3);
      font-size: 14px;
    }

    /* Night tab */
    .day-header {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 1.25rem;
    }

    .day-header label { font-size: 13px; color: var(--t2); }

    .day-header input[type=date] {
      padding: 8px 12px;
      border: 0.5px solid var(--b2);
      border-radius: var(--radius-md);
      background: var(--bg);
      color: var(--t1);
      font-size: 13px;
      font-family: 'DM Sans', sans-serif;
    }

    .day-header input[type=date]:focus { outline: none; }

    .night-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    @media (max-width: 540px) { .night-grid { grid-template-columns: 1fr; } }

    .night-panel {
      border: 0.5px solid var(--b3);
      border-radius: var(--radius-lg);
      background: var(--bg);
      overflow: hidden;
    }

    .night-panel-head {
      padding: 10px 15px;
      border-bottom: 0.5px solid var(--b3);
      font-size: 13px;
      font-weight: 500;
      color: var(--t2);
      background: var(--bg2);
    }

    .night-panel-body {
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      max-height: 360px;
      overflow-y: auto;
    }

    .pick-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 12px;
      border: 0.5px solid var(--b3);
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: background 0.1s;
      background: var(--bg);
      user-select: none;
    }

    .pick-item:hover { background: var(--bg2); }

    .pick-item.selected {
      border-color: #3B6D11;
      background: #EAF3DE;
    }

    .pick-item .check {
      width: 16px;
      height: 16px;
      border-radius: 4px;
      border: 1.5px solid var(--b2);
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 10px;
    }

    .pick-item.selected .check {
      background: #3B6D11;
      border-color: #3B6D11;
      color: #fff;
    }

    .pick-item .pname { font-size: 13px; font-weight: 500; flex: 1; }

    .did-item {
      padding: 9px 13px;
      border: 0.5px solid #C0DD97;
      border-radius: var(--radius-md);
      background: #EAF3DE;
      font-size: 13px;
      font-weight: 500;
      color: #27500A;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .did-item .remove {
      margin-left: auto;
      cursor: pointer;
      color: #3B6D11;
      font-size: 18px;
      line-height: 1;
      background: none;
      border: none;
      font-family: inherit;
    }

    .save-row {
      display: flex;
      justify-content: flex-end;
      margin-top: 1.25rem;
      gap: 10px;
      align-items: center;
    }

    .save-msg { font-size: 13px; color: #3B6D11; font-weight: 500; }

    /* History */
    .day-log {
      border: 0.5px solid var(--b3);
      border-radius: var(--radius-lg);
      overflow: hidden;
      margin-bottom: 8px;
    }

    .day-log-head {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 16px;
      background: var(--bg2);
      cursor: pointer;
      user-select: none;
    }

    .day-log-head .date { font-size: 14px; font-weight: 500; flex: 1; }
    .day-log-head .count { font-size: 12px; color: var(--t2); }
    .caret { font-size: 11px; color: var(--t2); transition: transform 0.2s; }
    .day-log.open .caret { transform: rotate(180deg); }

    .day-log-body {
      padding: 12px 16px;
      display: none;
      flex-wrap: wrap;
      gap: 6px;
      border-top: 0.5px solid var(--b3);
      background: var(--bg);
    }

    .day-log.open .day-log-body { display: flex; }

    .log-pill {
      font-size: 12px;
      font-weight: 500;
      padding: 4px 10px;
      border-radius: 20px;
      background: #EAF3DE;
      color: #27500A;
      border: 0.5px solid #C0DD97;
    }

    .section-note {
      font-size: 13px;
      color: var(--t2);
      margin-bottom: 1rem;
    }
  </style>
</head>
<body>
  <div class="app">
    <h1>Line Dance Tracker</h1>
    <p class="subtitle">Track your dances, your progress, and your nights out</p>

    <div class="tab-row">
      <button class="tab active" onclick="switchTab('know')">Dances I Know</button>
      <button class="tab" onclick="switchTab('learn')">Want to Learn</button>
      <button class="tab" onclick="switchTab('night')">My Night</button>
      <button class="tab" onclick="switchTab('log')">History</button>
    </div>

    <!-- KNOW -->
    <div id="tab-know" class="section visible">
      <div class="add-row">
        <input type="text" id="know-input" placeholder="Add a dance you know..." onkeydown="if(event.key==='Enter')addDance('know')">
        <button class="btn primary" onclick="addDance('know')">Add</button>
      </div>
      <div id="know-list" class="dance-list"></div>
    </div>

    <!-- LEARN -->
    <div id="tab-learn" class="section">
      <div class="add-row">
        <input type="text" id="learn-input" placeholder="Add a dance to learn..." onkeydown="if(event.key==='Enter')addDance('learn')">
        <button class="btn primary" onclick="addDance('learn')">Add</button>
      </div>
      <div id="learn-list" class="dance-list"></div>
    </div>

    <!-- NIGHT -->
    <div id="tab-night" class="section">
      <div class="day-header">
        <label>Date:</label>
        <input type="date" id="night-date">
      </div>
      <div class="night-grid">
        <div class="night-panel">
          <div class="night-panel-head">Dances I know — pick what you did</div>
          <div class="night-panel-body" id="pick-list"></div>
        </div>
        <div class="night-panel">
          <div class="night-panel-head">Tonight's dances</div>
          <div class="night-panel-body" id="did-list"></div>
        </div>
      </div>
      <div class="save-row">
        <span class="save-msg" id="save-msg"></span>
        <button class="btn primary" onclick="saveNight()">Save Night</button>
      </div>
    </div>

    <!-- LOG -->
    <div id="tab-log" class="section">
      <p class="section-note">Your dance nights, most recent first</p>
      <div id="log-list"></div>
    </div>
  </div>

  <script>
    const STORE_KEY = 'linedance_v1';

    function load() {
      try {
        const raw = localStorage.getItem(STORE_KEY);
        return raw ? JSON.parse(raw) : { know: [], learn: [], nights: {} };
      } catch(e) { return { know: [], learn: [], nights: {} }; }
    }

    function save(data) {
      try { localStorage.setItem(STORE_KEY, JSON.stringify(data)); } catch(e) {}
    }

    let state = load();
    let selectedDate = '';
    let nightSelections = {};

    function switchTab(tab) {
      const tabs = ['know', 'learn', 'night', 'log'];
      document.querySelectorAll('.tab').forEach((t, i) => {
        t.classList.toggle('active', tabs[i] === tab);
      });
      document.querySelectorAll('.section').forEach(s => s.classList.remove('visible'));
      document.getElementById('tab-' + tab).classList.add('visible');
      if (tab === 'night') renderNight();
      if (tab === 'log') renderLog();
    }

    function addDance(type) {
      const inp = document.getElementById(type + '-input');
      const name = inp.value.trim();
      if (!name) return;
      state[type].push({ id: Date.now() + '', name, added: new Date().toISOString() });
      save(state);
      inp.value = '';
      renderList(type);
    }

    function removeDance(type, id) {
      state[type] = state[type].filter(d => d.id !== id);
      save(state);
      renderList(type);
    }

    function moveToKnow(id) {
      const d = state.learn.find(x => x.id === id);
      if (!d) return;
      state.learn = state.learn.filter(x => x.id !== id);
      state.know.push({ ...d });
      save(state);
      renderList('learn');
      renderList('know');
    }

    function renderList(type) {
      const el = document.getElementById(type + '-list');
      if (!state[type].length) {
        el.innerHTML = `<div class="empty">${type === 'know' ? 'No dances yet — add your first!' : 'No dances on your wish list yet.'}</div>`;
        return;
      }
      el.innerHTML = state[type].map(d => `
        <div class="dance-item">
          <span class="name">${esc(d.name)}</span>
          ${type === 'learn' ? `<button class="btn sm success" onclick="moveToKnow('${d.id}')">I know it now!</button>` : ''}
          <button class="btn sm danger" onclick="removeDance('${type}','${d.id}')">Remove</button>
        </div>
      `).join('');
    }

    function initNightDate() {
      const inp = document.getElementById('night-date');
      const today = new Date().toISOString().slice(0, 10);
      inp.value = today;
      selectedDate = today;
      inp.onchange = () => {
        selectedDate = inp.value;
        loadNightSelections();
        renderPickList();
        renderDidList();
      };
    }

    function loadNightSelections() {
      nightSelections = {};
      const night = state.nights[selectedDate];
      if (night) night.forEach(id => nightSelections[id] = true);
    }

    function renderNight() {
      if (!selectedDate) initNightDate();
      selectedDate = document.getElementById('night-date').value || new Date().toISOString().slice(0, 10);
      loadNightSelections();
      renderPickList();
      renderDidList();
    }

    function renderPickList() {
      const el = document.getElementById('pick-list');
      if (!state.know.length) {
        el.innerHTML = `<div class="empty" style="padding:1.5rem .5rem">Add dances to "Dances I Know" first</div>`;
        return;
      }
      el.innerHTML = state.know.map(d => `
        <div class="pick-item ${nightSelections[d.id] ? 'selected' : ''}" onclick="togglePick('${d.id}')">
          <div class="check">${nightSelections[d.id] ? '&#10003;' : ''}</div>
          <span class="pname">${esc(d.name)}</span>
        </div>
      `).join('');
    }

    function renderDidList() {
      const el = document.getElementById('did-list');
      const dances = state.know.filter(d => nightSelections[d.id]);
      if (!dances.length) {
        el.innerHTML = `<div class="empty" style="padding:1.5rem .5rem">Nothing selected yet</div>`;
        return;
      }
      el.innerHTML = dances.map(d => `
        <div class="did-item">
          ${esc(d.name)}
          <button class="remove" onclick="togglePick('${d.id}')" title="Remove">&#215;</button>
        </div>
      `).join('');
    }

    function togglePick(id) {
      if (nightSelections[id]) delete nightSelections[id];
      else nightSelections[id] = true;
      renderPickList();
      renderDidList();
    }

    function saveNight() {
      if (!selectedDate) return;
      state.nights[selectedDate] = Object.keys(nightSelections);
      save(state);
      const msg = document.getElementById('save-msg');
      msg.textContent = 'Saved!';
      setTimeout(() => msg.textContent = '', 2500);
    }

    function renderLog() {
      const el = document.getElementById('log-list');
      const nights = Object.entries(state.nights).sort((a, b) => b[0].localeCompare(a[0]));
      if (!nights.length) {
        el.innerHTML = `<div class="empty">No nights logged yet. Go dance!</div>`;
        return;
      }
      el.innerHTML = nights.map(([date, ids]) => {
        const dances = ids.map(id => state.know.find(d => d.id === id)).filter(Boolean);
        const label = formatDate(date);
        const pills = dances.map(d => `<span class="log-pill">${esc(d.name)}</span>`).join('');
        return `
          <div class="day-log" onclick="this.classList.toggle('open')">
            <div class="day-log-head">
              <span class="date">${label}</span>
              <span class="count">${dances.length} dance${dances.length !== 1 ? 's' : ''}</span>
              <span class="caret">&#9660;</span>
            </div>
            <div class="day-log-body">${pills || '<span style="font-size:13px;color:#9e9d98">No dances recorded</span>'}</div>
          </div>`;
      }).join('');
    }

    function formatDate(d) {
      const [y, m, day] = d.split('-');
      const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      return `${months[+m - 1]} ${+day}, ${y}`;
    }

    function esc(s) {
      return String(s)
        .replace(/&/g,'&amp;')
        .replace(/</g,'&lt;')
        .replace(/>/g,'&gt;')
        .replace(/"/g,'&quot;');
    }

    renderList('know');
    renderList('learn');
    initNightDate();
  </script>
</body>
</html>
